{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-scheduling-profile.example/schemas/availability.response.schema.json",
  "title": "Availability Response",
  "description": "Response payload returned by a provider when queried for available scheduling slots.",
  "type": "object",
  "required": ["providerId", "slots", "truncated", "queriedAt"],
  "properties": {
    "providerId": {
      "type": "string",
      "description": "Identifier of the scheduling provider that produced this response."
    },
    "slots": {
      "type": "array",
      "description": "List of available time slots matching the query.",
      "items": {
        "$ref": "slot.schema.json"
      }
    },
    "truncated": {
      "type": "boolean",
      "description": "Whether the result set was truncated due to pagination limits."
    },
    "nextCursor": {
      "type": "string",
      "description": "Opaque cursor to fetch the next page of results. Present only when truncated is true."
    },
    "queriedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the query was executed."
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "providerId": "provider-acme-cal",
      "slots": [
        {
          "id": "slot-2026-04-20-0900",
          "start": "2026-04-20T09:00:00Z",
          "end": "2026-04-20T09:30:00Z",
          "providerId": "provider-acme-cal",
          "duration": "PT30M",
          "status": "available"
        },
        {
          "id": "slot-2026-04-20-1000",
          "start": "2026-04-20T10:00:00Z",
          "end": "2026-04-20T10:30:00Z",
          "providerId": "provider-acme-cal",
          "duration": "PT30M",
          "status": "available"
        }
      ],
      "truncated": false,
      "queriedAt": "2026-04-16T12:00:00Z"
    },
    {
      "providerId": "provider-acme-cal",
      "slots": [
        {
          "id": "slot-2026-05-01-0800",
          "start": "2026-05-01T08:00:00-05:00",
          "end": "2026-05-01T09:00:00-05:00",
          "providerId": "provider-acme-cal",
          "duration": "PT1H",
          "status": "available"
        }
      ],
      "truncated": true,
      "nextCursor": "eyJwYWdlIjozfQ==",
      "queriedAt": "2026-04-16T14:30:00Z"
    }
  ]
}
