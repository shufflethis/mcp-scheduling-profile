{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcp-scheduling-profile.example/schemas/slot.schema.json",
  "title": "Scheduling Time Slot",
  "description": "Represents a single bookable time slot offered by a scheduling provider.",
  "type": "object",
  "required": ["id", "start", "end", "providerId", "duration", "status"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this slot."
    },
    "start": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 date-time when the slot begins."
    },
    "end": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 date-time when the slot ends."
    },
    "providerId": {
      "type": "string",
      "description": "Identifier of the scheduling provider that owns this slot."
    },
    "duration": {
      "type": "string",
      "pattern": "^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+W)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$",
      "description": "ISO 8601 duration of the slot (e.g. PT30M for 30 minutes)."
    },
    "status": {
      "type": "string",
      "enum": ["available", "held", "booked"],
      "description": "Current status of the slot."
    },
    "metadata": {
      "type": "object",
      "description": "Optional provider-specific metadata.",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": "slot-2026-04-20-0900",
      "start": "2026-04-20T09:00:00Z",
      "end": "2026-04-20T09:30:00Z",
      "providerId": "provider-acme-cal",
      "duration": "PT30M",
      "status": "available"
    },
    {
      "id": "slot-2026-04-21-1400",
      "start": "2026-04-21T14:00:00+02:00",
      "end": "2026-04-21T15:00:00+02:00",
      "providerId": "provider-acme-cal",
      "duration": "PT1H",
      "status": "held",
      "metadata": {
        "roomId": "conf-room-3",
        "meetingLink": "https://meet.example.com/abc-def"
      }
    }
  ]
}
